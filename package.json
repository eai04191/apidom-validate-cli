{
    "name": "apidom-validate-cli",
    "version": "0.0.0-semantically-released",
    "description": "CLI tool that validates OpenAPI / AsyncAPI files with the same diagnostics as editor.swagger.io (via @swagger-api/apidom-ls)",
    "keywords": [
        "apidom",
        "apidom-validate",
        "asyncapi",
        "cli",
        "openapi",
        "swagger",
        "validator"
    ],
    "homepage": "https://github.com/eai04191/apidom-validate-cli#readme",
    "bugs": {
        "url": "https://github.com/eai04191/apidom-validate-cli/issues"
    },
    "license": "MIT",
    "author": "y.takahashi <eai@mizle.net> (https://github.com/eai04191)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eai04191/apidom-validate-cli.git"
    },
    "bin": "./bin/apidom-validate-cli.mjs",
    "files": [
        "bin"
    ],
    "type": "module",
    "scripts": {
        "check": "run-p typecheck lint format:check test",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "test": "node --test --test-force-exit",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@swagger-api/apidom-ls": "1.11.3",
        "chalk": "5.6.2",
        "citty": "0.2.2",
        "vscode-languageserver-textdocument": "1.0.12"
    },
    "devDependencies": {
        "@semantic-release/exec": "7.1.0",
        "@tsconfig/strictest": "2.0.8",
        "@types/node": "24.13.3",
        "npm-run-all2": "9.0.2",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0",
        "oxlint-config-presets": "0.1.16",
        "oxlint-tsgolint": "0.24.0",
        "semantic-release": "25.0.7",
        "typescript": "7.0.2",
        "vscode-languageserver-types": "3.18.0"
    },
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "11.13.0",
            "onFail": "download"
        },
        "runtime": {
            "name": "node",
            "version": "26",
            "onFail": "download"
        }
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@11.13.0"
}
